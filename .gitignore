# Hyperi Developer Environment - Git Ignore

# OS files
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# IDE files
.vscode/
.idea/
*.iml

# Logs and temp files
*.log
*.tmp
*.temp
*.bak
*.backup
*.orig
.tmp/
tmp/
temp/

# Credentials and secrets
.env
*.secret
*.key
*.pem
credentials.json
.aws/
.azure/

# Build artifacts
build/
dist/
*.egg-info/
__pycache__/
*.pyc
node_modules/
package-lock.json

# Testing
.coverage
coverage/
test-results/
.pytest_cache/

# Project specific
downloads/
installers/
*.local.sh
local-config/

# AI assistant work files - never commit (local only, public repo)
ai/
STATE.md
CLAUDE.md
TODO.md
.claude/
*claude*.tmp
*claude*.draft
.cline/
.aider/
.cursor/
.continue/

# Keep these even though they have claude in name
!lib.sh
!install-*claude*.shansible/tests/.env
ansible/tests/.env
**/.env

# Local environment files (never commit -- contain secrets)
.env.*
!.env.example
!.env.example.*

# Local working files (not committed)
#
# Authoritative protection for hyperi-ai content is .git/info/exclude
# (per-repo, never committed). The entries below ALSO appear there;
# duplicating them in .gitignore is belt-and-braces -- if a developer
# uses a tool that doesn't respect .git/info/exclude (unusual), the
# .gitignore still catches it. We do not RELY on these being committed
# in .gitignore -- attach surgically appends them if missing, leaves
# them alone if already present.
docs/superpowers/
.mcp.json
.ai-version

# hyperi-ai per-project context + tool-specific equivalents.
# Real files in project tree (Claude Code / Codex / Gemini / Cursor
# all load these from project root natively). Local-only, never
# committed -- mirrored in .git/info/exclude.
AGENTS.md
GEMINI.md
.codex/
.gemini/
.cursorrules

# Git worktrees (local dev convenience)
.worktrees/

# Node / TypeScript build artefacts
out/
.next/
.turbo/
.vite/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo

# Test / coverage
.nyc_output/

# Yarn / pnpm / npm
.pnpm-store/
.yarn/cache
.yarn/install-state.gz
.pnp.*
