# Test Infrastructure Configuration
# Copy this to .env and fill in your values
# .env is gitignored - never commit credentials!

# =============================================================================
# PROXMOX (for Fedora/Ubuntu testing)
# =============================================================================
# Your Proxmox server connection details
PROXMOX_HOST=proxmox.example.com
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=  # Optional - leave empty if using SSH keys
PROXMOX_NODE=pve
PROXMOX_API_VERIFY_SSL=false

# Fedora Test VM
PROXMOX_FEDORA_VMID=2005
PROXMOX_FEDORA_SNAPSHOT=initial_build
PROXMOX_FEDORA_HOSTNAME=dfe-dev.example.com
PROXMOX_FEDORA_USER=dfe
PROXMOX_FEDORA_PASSWORD=dfe  # Optional - omit from inventory if using SSH keys
PROXMOX_FEDORA_SSH_PORT=22

# Ubuntu Test VM
PROXMOX_UBUNTU_VMID=2006
PROXMOX_UBUNTU_SNAPSHOT=initial_build
PROXMOX_UBUNTU_HOSTNAME=dfe-dev-u.example.com
PROXMOX_UBUNTU_USER=dfe
PROXMOX_UBUNTU_PASSWORD=dfe  # Optional - omit from inventory if using SSH keys
PROXMOX_UBUNTU_SSH_PORT=22

# -----------------------------------------------------------------------------
# CLONE-TEST (emulates the auto desktop image cycle: clone -> test -> delete)
# -----------------------------------------------------------------------------
# A throwaway full-install test. Clones the base image template to a temporary
# VM, runs the playbook against it, asserts, then DELETES the clone. This is
# the from-scratch counterpart to the remediation test (which proves an OLD
# host converges to current); together they cover both paths a real host takes.
#
# Every internal name lives here, never in committed YAML — the playbooks read
# these via lookup('env', ...) so the repo leaks no infra topology.
PROXMOX_TEMPLATE_VMID=9001
PROXMOX_TEMPLATE_NAME=ubuntu-noble-example-base

# Clone target. Use a VMID range reserved for throwaway tests so a mistyped id
# can never collide with a real VM.
PROXMOX_CLONE_VMID=9901
PROXMOX_CLONE_NAME=hyperi-developer-clonetest
PROXMOX_CLONE_USER=ubuntu
PROXMOX_CLONE_SSH_PORT=22

# Safety: the clone-test DELETES the VM it created. It must refuse to delete
# anything whose VMID is outside this range, so a misconfigured run cannot
# destroy a real machine.
PROXMOX_CLONE_VMID_MIN=9900
PROXMOX_CLONE_VMID_MAX=9999

# Set false to leave the clone running after a failure, for debugging.
PROXMOX_CLONE_DESTROY_ON_FAILURE=true

# =============================================================================
# TEST SETTINGS
# =============================================================================
# Ansible connection settings
ANSIBLE_SSH_RETRIES=3
ANSIBLE_TIMEOUT=30
